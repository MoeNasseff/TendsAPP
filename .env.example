# Supabase (client-side, safe to expose — protected by Row-Level Security)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public Telegram bot username (not secret — used to build the "Connect
# Telegram" deep link t.me/<username>?start=<userId>)
VITE_TELEGRAM_BOT_USERNAME=

# Public VAPID key (not secret — used by the browser to subscribe to push;
# the matching VAPID_PRIVATE_KEY below must stay server-side only)
VITE_VAPID_PUBLIC_KEY=

# Everything below is server-side only and does NOT belong in this file's
# real values — set these as Supabase Edge Function secrets instead
# (`supabase secrets set KEY=value`), never as VITE_-prefixed client vars.
# See supabase/README.md for the full setup guide.
#
# TELEGRAM_BOT_TOKEN=            # from @BotFather            [configured]
# TELEGRAM_WEBHOOK_SECRET=       # random string you choose    [configured]
# CRON_SECRET=                   # random string you choose    [configured]
# VAPID_PRIVATE_KEY=             # `npx web-push generate-vapid-keys` [configured]
# SMTP_HOST=                                                    [TODO]
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# WHATSAPP_ENABLED=false                                        [configured, disabled]
# WHATSAPP_ACCESS_TOKEN=                                        [TODO if enabling]
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
